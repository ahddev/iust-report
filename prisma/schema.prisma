generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Report {
  id            String   @id @default(cuid())
  name          String
  nationalId    String
  collegeId     String
  contactNumber String   @default("")
  issue         String
  createdAt     DateTime @default(now())
  submittedBy   String?
}